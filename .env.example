# Root Environment Variables Reference
# Do not copy this file directly. Instead, copy the service-specific templates:
# - backend/.env.example -> backend/.env
# - frontend/.env.example -> frontend/.env

# Backend Configuration
PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
CLIENT_URL=your_frontend_client_url_here

# Frontend Configuration
VITE_API_BASE_URL=your_api_base_url_here
VITE_API_URL=your_backend_base_url_here
VITE_APP_NAME=Springfield ERP
