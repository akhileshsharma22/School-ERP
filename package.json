{
  "name": "springfield-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Springfield ERP - A production-grade School ERP System built using the MERN Stack.",
  "author": "Akhilesh Sharma <akhileshsharmaldh2004@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akhileshsharma22/School-ERP.git"
  },
  "keywords": [
    "school-erp",
    "mern-stack",
    "react",
    "express",
    "mongodb",
    "redux-toolkit",
    "education-management"
  ],
  "homepage": "https://github.com/akhileshsharma22/School-ERP#readme",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "start": "npm --prefix backend run start",
    "seed:admin": "npm --prefix backend run seed:admin",
    "install:all": "npm install --prefix frontend && npm install --prefix backend"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  }
}
